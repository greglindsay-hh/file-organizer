#!/usr/bin/env python3
"""
Downloads Organizer
-------------------
Reads a list of client names from ~/Downloads/clients.csv,
scans the TOP LEVEL of ~/Downloads only (files and subfolders),
matches each item's name to a client, previews the plan, then moves
items into ~/Downloads/Organized/<ClientName>/ upon confirmation.

Subfolders are moved as a whole unit — their contents are never touched.
Unmatched items go to ~/Downloads/Organized/Other/
"""

import csv
import shutil
from pathlib import Path
from collections import defaultdict


DOWNLOADS = Path.home() / "Downloads"
CSV_PATH = DOWNLOADS / "clients.csv"
ORGANIZED = DOWNLOADS / "Organized"
SCRIPT_NAME = Path(__file__).name


def load_clients():
    """
    Returns a list of (canonical_name, [variation1, variation2, ...]) tuples.
    Column A is the canonical name (used as the folder name).
    Any additional columns in the same row are treated as name variations.
    All variations — including the canonical name itself — are matched against item names.
    """
    if not CSV_PATH.exists():
        print(f"\n  Could not find clients.csv in {DOWNLOADS}")
        print("  Please save your client list as 'clients.csv' in your Downloads folder.")
        print("  Column A = folder name, additional columns = name variations.\n")
        return []

    clients = []
    with open(CSV_PATH, "r", encoding="utf-8-sig") as f:
        for row in csv.reader(f):
            names = [cell.strip() for cell in row if cell.strip()]
            if names:
                canonical = names[0]
                variations = names  # includes canonical itself
                clients.append((canonical, variations))

    return clients


def find_match(name, clients):
    """Check a file or folder name against every client variation; return canonical name if matched."""
    lower = name.lower()
    for canonical, variations in clients:
        if any(v.lower() in lower for v in variations):
            return canonical
    return None


def collect_items():
    """Return all top-level files and folders in Downloads, skipping special items."""
    items = []
    for entry in DOWNLOADS.iterdir():
        if entry.name.startswith("."):
            continue
        if entry == ORGANIZED:
            continue
        if entry == CSV_PATH:
            continue
        if entry.name == SCRIPT_NAME:
            continue
        items.append(entry)
    return sorted(items, key=lambda x: (x.is_file(), x.name.lower()))


def safe_destination(dest_folder, item):
    """Return a destination path that doesn't already exist (appends _1, _2 … if needed)."""
    dest = dest_folder / item.name
    if not dest.exists():
        return dest

    counter = 1
    if item.is_dir():
        while dest.exists():
            dest = dest_folder / f"{item.name}_{counter}"
            counter += 1
    else:
        stem = Path(item.name).stem
        suffix = Path(item.name).suffix
        while dest.exists():
            dest = dest_folder / f"{stem}_{counter}{suffix}"
            counter += 1
    return dest


def main():
    print("\n=== Downloads Organizer ===\n")

    # Load clients
    clients = load_clients()
    if not clients:
        return
    total_variations = sum(len(v) - 1 for _, v in clients)
    print(f"  Loaded {len(clients)} clients ({total_variations} name variation(s)) from clients.csv")

    # Collect top-level items
    all_items = collect_items()
    if not all_items:
        print("  No items found in Downloads.\n")
        return
    print(f"  Found {len(all_items)} item(s) to evaluate\n")

    # Build the move plan
    plan = defaultdict(list)
    for item in all_items:
        match = find_match(item.name, clients)
        plan[match if match else "Other"].append(item)

    # ── Preview ──────────────────────────────────────────────────────────────
    matched_count = sum(len(v) for k, v in plan.items() if k != "Other")
    other_count = len(plan.get("Other", []))

    print("ITEMS TO BE ORGANIZED:")
    print("─" * 56)

    def label(item):
        return f"{item.name}/" if item.is_dir() else item.name

    # Client folders (alphabetical)
    for folder in sorted(k for k in plan if k != "Other"):
        print(f"\n  {folder}/")
        for item in plan[folder]:
            print(f"      → {label(item)}")

    # Other folder
    if plan["Other"]:
        print(f"\n  Other/  (no client match found)")
        for item in plan["Other"]:
            print(f"      → {label(item)}")

    print("\n" + "─" * 56)
    print(f"  {matched_count} item(s) matched to clients")
    print(f"  {other_count} item(s) → Other")
    print(f"  Destination: {ORGANIZED}/")
    print("─" * 56)

    # ── Confirm ───────────────────────────────────────────────────────────────
    answer = input("\nType YES to move items, or NO to cancel: ").strip()
    if answer != "YES":
        print("\n  Cancelled. No items were moved.\n")
        return

    # ── Execute ───────────────────────────────────────────────────────────────
    moved, errors = 0, 0

    for folder_name, items in plan.items():
        dest_folder = ORGANIZED / folder_name
        dest_folder.mkdir(parents=True, exist_ok=True)

        for item in items:
            dest = safe_destination(dest_folder, item)
            try:
                shutil.move(str(item), str(dest))
                moved += 1
            except Exception as e:
                print(f"  Could not move {item.name}: {e}")
                errors += 1

    print(f"\n  Done! {moved} item(s) moved to {ORGANIZED}/")
    if errors:
        print(f"  {errors} item(s) could not be moved (see messages above)")
    print()


if __name__ == "__main__":
    main()
